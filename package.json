{
  "name": "sk-chat",
  "version": "0.1.3",
  "description": "React chat assistant that captures scoped website content as markdown and screenshot context.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/index.css"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "peerDependencies": {
    "@ai-sdk/react": "^3.0.0",
    "@assistant-ui/react": "^0.14.0",
    "@assistant-ui/react-ai-sdk": "^1.3.0",
    "ai": "^6.0.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.69",
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-collapsible": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codex-pet-web": "^0.3.1",
    "codex-pet-web-react": "^0.3.1",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.5.0",
    "react-markdown": "^10.1.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "turndown": "^7.2.4",
    "tw-animate-css": "^1.4.0"
  },
